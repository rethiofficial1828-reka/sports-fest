# Supabase (Required for Google Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SportsFest

# JWT Authentication
JWT_SECRET=a-very-long-and-secure-secret-key-that-exceeds-32-characters-for-jwt-signing

# Email (Resend) - Optional but recommended for production emails
RESEND_API_KEY=re_xxxx

# Rate Limiting (Upstash Redis) - Optional
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Sentry (Error Tracking) - Optional
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Secure Admin Default Configuration
NEXT_PUBLIC_ADMIN_EMAIL=admin@sportsfest.in
NEXT_PUBLIC_ADMIN_PASSWORD=AdminPassword2026!
